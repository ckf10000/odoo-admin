        </record>
<record id="media_file_3" model="learn.media">
            <field name="name">Unit1_随堂练习纸.pdf</field>
            <field name="media_type">file</field>
            <field name="file_name">Unit1_随堂练习纸.pdf</field>
        </record>
<record id="media_file_4" model="learn.media">
