        </record>
<record id="article_knowledge_1" model="learn.article">
            <field name="name">核心词汇</field>
            <field name="article_type">knowledge</field>
            <field name="content"><![CDATA[<![CDATA[<ul>
<li><b>tall</b> - 高的</li>
<li><b>short</b> - 矮的</li>
<li><b>long</b> - 长的</li>
<li><b>curly</b> - 卷曲的</li>
<li><b>straight</b> - 直的</li>
<li><b>glasses</b> - 眼镜</li>
</ul>]]></field>
        </record>
<record id="article_knowledge_2" model="learn.article">
            <field name="name">重点句型</field>
            <field name="article_type">knowledge</field>
            <field name="content"><![CDATA[<![CDATA[<ol>
<li>What does he/she look like? — 他/她长什么样？</li>
<li>He/She has long hair. — 他/她有长头发。</li>
<li>He/She wears glasses. — 他/她戴眼镜。</li>
</ol>]]></field>
        </record>
        <record id="group_g5ed_video_1" model="learn.group">
            <field name="name">Unit 1 教学视频</field>
            <field name="selector_id" ref="selector_g5_english_hunan_26down"/>
            <field name="process_id" ref="process_online_video"/>
            <field name="sequence">10</field>


        </record>


        <record id="line_g5ed_video_lesson1" model="learn.group.line">
            <field name="group_id" ref="group_g5ed_video_1"/>
            <field name="media_id" ref="media_video_1"/>
            <field name="sequence">10</field>
        </record>
        <record id="line_g5ed_video_lesson2" model="learn.group.line">
            <field name="group_id" ref="group_g5ed_video_1"/>
            <field name="media_id" ref="media_video_2"/>
            <field name="sequence">20</field>
        </record>

        <!-- 资料下载组 -->
        <record id="group_g5ed_download_1" model="learn.group">
            <field name="name">Unit 1 学习资料</field>
            <field name="selector_id" ref="selector_g5_english_hunan_26down"/>
