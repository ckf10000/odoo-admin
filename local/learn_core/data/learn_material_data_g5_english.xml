            <field name="media_type">video</field>
            <field name="url">https://example.com/videos/g5/unit1/lesson1</field>
            <field name="duration">900</field>
        </record>
<record id="media_video_2" model="learn.media">
            <field name="name">Unit 1 - What does she look like? 第2课时</field>
            <field name="media_type">video</field>
            <field name="url">https://example.com/videos/g5/unit1/lesson2</field>
