<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ========== 五年级英语（下册 湘少版） 试题数据 ========== -->

        <!-- 试卷 -->
        <record id="exam_g5ed_unit1" model="learn.content">
            <field name="name">五年级英语下册 - Unit 1 单元测试</field>
            <field name="content_type">exam</field>
            <field name="subject">英语</field>
            <field name="grade">五年级</field>
            <field name="semester">autumn</field>
            <field name="total_score">100</field>
            <field name="pass_score">60</field>
            <field name="time_limit">40</field>
            <field name="state">published</field>
            <field name="selector_id" ref="selector_g5_english_hunan_26down"/>        </record>

        <!-- 题目 1：单选题 - 词汇 -->
        <record id="question_g5ed_u1_q1" model="learn.question">
                        <field name="name">Unit 1 词汇单选</field>
            <field name="question_type">single_choice</field>
            <field name="stem"><![CDATA[<p>"apple" 的中文意思是？</p>]]></field>
            <field name="option_a">香蕉</field>
            <field name="option_b">苹果</field>
            <field name="option_c">橘子</field>
            <field name="option_d">葡萄</field>
            <field name="correct_answer">B</field>
            <field name="answer_explanation"><![CDATA[<p>apple = 苹果，是常见水果词汇。</p>]]></field>            <field name="difficulty">easy</field>        </record>

        <!-- 题目 2：单选题 - 语法 -->
        <record id="question_g5ed_u1_q2" model="learn.question">
                        <field name="name">Unit 1 语法单选</field>
            <field name="question_type">single_choice</field>
            <field name="stem"><![CDATA[<p>She ___ a student.</p>]]></field>
            <field name="option_a">am</field>
            <field name="option_b">is</field>
            <field name="option_c">are</field>
            <field name="option_d">be</field>
            <field name="correct_answer">B</field>
            <field name="answer_explanation"><![CDATA[<p>第三人称单数 she 后用 is。</p>]]></field>            <field name="difficulty">easy</field>        </record>

        <!-- 题目 3：多选题 -->
        <record id="question_g5ed_u1_q3" model="learn.question">
                        <field name="name">Unit 1 多选</field>
            <field name="question_type">multi_choice</field>
            <field name="stem"><![CDATA[<p>以下哪些是水果？（多选）</p>]]></field>
            <field name="option_a">Apple</field>
            <field name="option_b">Car</field>
            <field name="option_c">Banana</field>
            <field name="option_d">Dog</field>
            <field name="option_e">Orange</field>
            <field name="correct_answer">ACE</field>
            <field name="answer_explanation"><![CDATA[<p>Apple、Banana、Orange 都是水果。</p>]]></field>            <field name="difficulty">medium</field>        </record>

        <!-- 题目 4：填空题 -->
        <record id="question_g5ed_u1_q4" model="learn.question">
                        <field name="name">Unit 1 填空</field>
            <field name="question_type">fill_blank</field>
            <field name="stem"><![CDATA[<p>I ___ (be) a teacher. （用 be 动词的正确形式填空）</p>]]></field>
            <field name="correct_answer">am</field>
            <field name="answer_explanation"><![CDATA[<p>第一人称 I 后用 am。</p>]]></field>            <field name="difficulty">easy</field>        </record>

        <!-- 题目 5：判断题 -->
        <record id="question_g5ed_u1_q5" model="learn.question">
                        <field name="name">Unit 1 判断</field>
            <field name="question_type">true_false</field>
            <field name="stem"><![CDATA[<p>"cat" 的意思是"猫"。</p>]]></field>
            <field name="correct_answer">A</field>
            <field name="answer_explanation"><![CDATA[<p>cat = 猫，正确。</p>]]></field>            <field name="difficulty">easy</field>        </record>

        <!-- ========== 内容组：单元测试 ========== -->

        <record id="group_g5ed_unit1_test" model="learn.group">
            <field name="name">Unit 1 单元测试</field>
            <field name="selector_id" ref="selector_g5_english_hunan_26down"/>
            <field name="process_id" ref="process_unit_test"/>        </record>


        <record id="line_g5ed_u1_q1" model="learn.group.line">
            <field name="group_id" ref="group_g5ed_unit1_test"/>
            <field name="question_id" ref="question_g5ed_u1_q1"/>        </record>
        <record id="line_g5ed_u1_q2" model="learn.group.line">
            <field name="group_id" ref="group_g5ed_unit1_test"/>
            <field name="question_id" ref="question_g5ed_u1_q2"/>        </record>
        <record id="line_g5ed_u1_q3" model="learn.group.line">
            <field name="group_id" ref="group_g5ed_unit1_test"/>
            <field name="question_id" ref="question_g5ed_u1_q3"/>        </record>
        <record id="line_g5ed_u1_q4" model="learn.group.line">
            <field name="group_id" ref="group_g5ed_unit1_test"/>
            <field name="question_id" ref="question_g5ed_u1_q4"/>        </record>
        <record id="line_g5ed_u1_q5" model="learn.group.line">
            <field name="group_id" ref="group_g5ed_unit1_test"/>
            <field name="question_id" ref="question_g5ed_u1_q5"/>        </record>


    </data>
</odoo>
