<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ========== 单词组 视图 ========== -->

    <record id="view_learn_word_group_tree" model="ir.ui.view">
        <field name="name">learn.word.group.tree</field>
        <field name="model">learn.word.group</field>
        <field name="arch" type="xml">
            <tree string="单词组">
                <field name="name"/>
                <field name="selector_id"/>
                <field name="selector_process_id"/>
            </tree>
        </field>
    </record>

    <record id="view_learn_word_group_form" model="ir.ui.view">
        <field name="name">learn.word.group.form</field>
        <field name="model">learn.word.group</field>
        <field name="arch" type="xml">
            <form string="单词组">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="selector_id"/>
                            <field name="selector_process_id"/>
                        </group>
                        <group>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="单词列表" name="words">
                            <field name="line_ids" nolabel="1">
                                <tree editable="bottom">
                                    <field name="word_id"/>
                                    <field name="phonetic"/>
                                    <field name="meaning"/>
                                    <field name="sequence" widget="handle"/>
                                </tree>
                            </field>
                        </page>
                        <page string="描述" name="description">
                            <field name="description"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
