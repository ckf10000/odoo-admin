<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ========== 选择器 视图 ========== -->

    <record id="view_learn_selector_form" model="ir.ui.view">
        <field name="name">learn.selector.form</field>
        <field name="model">learn.selector</field>
        <field name="arch" type="xml">
            <form string="选择器">
                <sheet>
                    <group>
                        <group>
                            <field name="profile_id"/>
                            <field name="category_id"/>
                            <field name="stage_id"/>
                            <field name="class_id"/>
                            <field name="subject_id"/>
                            <field name="version_id"/>
                            <field name="year_id"/>
                            <field name="semester_id"/>
                        </group>
                        <group>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="学习过程分类（来自模板）" name="processes">
                            <field name="process_line_ids" nolabel="1">
                                <tree create="0" delete="0" edit="0">
                                    <field name="sequence_str" string="排序"/>
                                    <field name="process_id"/>
                                </tree>
                            </field>
                        </page>
                        <page string="地区" name="regions">
                            <field name="region_ids" nolabel="1" widget="many2many_tags"/>
                        </page>
                        <page string="备注" name="notes">
                            <field name="description"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
