<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ==================== 知识点条目：列表视图 ==================== -->
    <record id="view_learn_item_tree" model="ir.ui.view">
        <field name="name">learn.item.tree</field>
        <field name="model">learn.item</field>
        <field name="arch" type="xml">
            <tree string="知识点条目">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="item_type" widget="badge"
                       decoration-success="item_type == 'word'"
                       decoration-info="item_type == 'character'"
                       decoration-warning="item_type == 'vocabulary'"
                       decoration-danger="item_type == 'formula'"
                       decoration-muted="item_type == 'term'"/>
                <field name="meaning"/>
                <field name="difficulty" widget="badge"/>
                <field name="content_id" invisible="1"/>
            </tree>
        </field>
    </record>

    <!-- ==================== 知识点条目：表单视图 ==================== -->
    <record id="view_learn_item_form" model="ir.ui.view">
        <field name="name">learn.item.form</field>
        <field name="model">learn.item</field>
        <field name="arch" type="xml">
            <form string="知识点条目">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                    </div>
                    <group>
                        <group>
                            <field name="name" string="条目名称"/>
                            <field name="item_type"/>
                            <field name="difficulty"/>
                            <field name="sequence"/>
                            <field name="content_id" invisible="1"/>
                        </group>
                        <group>
                            <field name="meaning" nolabel="1" colspan="2"
                                   placeholder="释义（必填）"/>
                        </group>
                    </group>

                    <!-- ===== 英语单词专用 ===== -->
                    <group string="英语单词信息"
                           invisible="item_type != 'word'">
                        <group>
                            <field name="pronunciation" string="音标"/>
                            <field name="part_of_speech" string="词性"/>
                        </group>
                        <group>
                            <field name="example" nolabel="1"
                                   placeholder="英文例句"/>
                            <field name="example_translation" nolabel="1"
                                   placeholder="例句中文翻译"/>
                        </group>
                    </group>

                    <!-- ===== 语文生字专用 ===== -->
                    <group string="语文生字信息"
                           invisible="item_type != 'character'">
                        <group>
                            <field name="char_pinyin" string="拼音"/>
                            <field name="char_radical" string="部首"/>
                            <field name="char_strokes" string="笔画数"/>
                            <field name="char_structure" string="字形结构"/>
                        </group>
                        <group>
                            <field name="char_stroke_order" nolabel="1"
                                   placeholder="笔顺（如：横竖横折撇捺）"/>
                        </group>
                    </group>

                    <!-- ===== 语文词语专用 ===== -->
                    <group string="语文词语信息"
                           invisible="item_type != 'vocabulary'">
                        <group>
                            <field name="vocab_synonyms" nolabel="1"
                                   placeholder="近义词（多个用逗号分隔）"/>
                            <field name="vocab_antonyms" nolabel="1"
                                   placeholder="反义词（多个用逗号分隔）"/>
                        </group>
                        <group>
                            <field name="vocab_sentence" nolabel="1"
                                   placeholder="造句"/>
                        </group>
                    </group>

                    <!-- ===== 拼音专用 ===== -->
                    <group string="拼音信息"
                           invisible="item_type != 'pinyin'">
                        <group>
                            <field name="pinyin_initial" string="声母"/>
                            <field name="pinyin_final" string="韵母"/>
                            <field name="pinyin_tone" string="声调"/>
                        </group>
                    </group>

                    <!-- ===== 公式专用 ===== -->
                    <group string="公式信息"
                           invisible="item_type != 'formula'">
                        <group>
                            <field name="formula_expression" nolabel="1"
                                   placeholder="公式表达式"/>
                            <field name="formula_variables" nolabel="1"
                                   placeholder="变量说明"/>
                        </group>
                    </group>

                    <!-- ===== 多媒体（通用） ===== -->
                    <group string="多媒体">
                        <group>
                            <field name="audio_file" filename="audio_filename"
                                   string="音频"/>
                            <field name="audio_filename" invisible="1"/>
                        </group>
                        <group>
                            <field name="image" widget="image" string="配图"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ==================== 知识点条目：搜索视图 ==================== -->
    <record id="view_learn_item_search" model="ir.ui.view">
        <field name="name">learn.item.search</field>
        <field name="model">learn.item</field>
        <field name="arch" type="xml">
            <search string="搜索知识点">
                <field name="name"/>
                <field name="meaning"/>
                <field name="char_pinyin"/>
                <field name="pronunciation"/>

                <!-- 按类型筛选 -->
                <filter name="filter_type_word" string="英语单词"
                        domain="[('item_type', '=', 'word')]"/>
                <filter name="filter_type_character" string="语文生字"
                        domain="[('item_type', '=', 'character')]"/>
                <filter name="filter_type_vocabulary" string="语文词语"
                        domain="[('item_type', '=', 'vocabulary')]"/>
                <filter name="filter_type_pinyin" string="拼音"
                        domain="[('item_type', '=', 'pinyin')]"/>
                <filter name="filter_type_formula" string="公式"
                        domain="[('item_type', '=', 'formula')]"/>
                <filter name="filter_type_term" string="通用术语"
                        domain="[('item_type', '=', 'term')]"/>

                <separator/>

                <!-- 按难度 -->
                <filter name="filter_easy" string="简单"
                        domain="[('difficulty', '=', 'easy')]"/>
                <filter name="filter_medium" string="中等"
                        domain="[('difficulty', '=', 'medium')]"/>
                <filter name="filter_hard" string="困难"
                        domain="[('difficulty', '=', 'hard')]"/>

                <!-- 英语词性分组 -->
                <group expand="0" string="英语-词性">
                    <filter name="pos_noun" string="名词"
                            domain="[('part_of_speech', '=', 'noun')]"/>
                    <filter name="pos_verb" string="动词"
                            domain="[('part_of_speech', '=', 'verb')]"/>
                    <filter name="pos_adj" string="形容词"
                            domain="[('part_of_speech', '=', 'adj')]"/>
                    <filter name="pos_adv" string="副词"
                            domain="[('part_of_speech', '=', 'adv')]"/>
                    <filter name="pos_phrase" string="短语"
                            domain="[('part_of_speech', '=', 'phrase')]"/>
                </group>

                <!-- 生字结构分组 -->
                <group expand="0" string="生字-结构">
                    <filter name="struct_single" string="独体字"
                            domain="[('char_structure', '=', 'single')]"/>
                    <filter name="struct_lr" string="左右结构"
                            domain="[('char_structure', '=', 'left_right')]"/>
                    <filter name="struct_ud" string="上下结构"
                            domain="[('char_structure', '=', 'up_down')]"/>
                    <filter name="struct_hs" string="半包围"
                            domain="[('char_structure', '=', 'half_surround')]"/>
                    <filter name="struct_fs" string="全包围"
                            domain="[('char_structure', '=', 'full_surround')]"/>
                </group>

                <!-- 声调分组 -->
                <group expand="0" string="拼音-声调">
                    <filter name="tone_1" string="一声"
                            domain="[('pinyin_tone', '=', '1')]"/>
                    <filter name="tone_2" string="二声"
                            domain="[('pinyin_tone', '=', '2')]"/>
                    <filter name="tone_3" string="三声"
                            domain="[('pinyin_tone', '=', '3')]"/>
                    <filter name="tone_4" string="四声"
                            domain="[('pinyin_tone', '=', '4')]"/>
                    <filter name="tone_0" string="轻声"
                            domain="[('pinyin_tone', '=', '0')]"/>
                </group>
            </search>
        </field>
    </record>



</odoo>
