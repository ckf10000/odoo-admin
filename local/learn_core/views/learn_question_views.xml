<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- 题目列表视图 -->
    <record id="view_learn_question_tree" model="ir.ui.view">
        <field name="name">learn.question.tree</field>
        <field name="model">learn.question</field>
        <field name="arch" type="xml">
            <tree string="题目列表">
                <field name="name"/>
                <field name="question_type" widget="badge"/>
                <field name="difficulty" widget="badge"/>
                <field name="selector_ids" optional="hide"/>
            </tree>
        </field>
    </record>

    <!-- 题目表单视图 -->
    <record id="view_learn_question_form" model="ir.ui.view">
        <field name="name">learn.question.form</field>
        <field name="model">learn.question</field>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <form string="题目">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="题目标题"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="question_type"/>
                            <field name="default_score"/>
                            <field name="difficulty"/>
                        </group>
                        <group>
                            <field name="selector_ids"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="题干" name="stem">
                            <field name="stem" widget="html" nolabel="1"/>
                            <field name="stem_image" widget="image" nolabel="1"/>
                        </page>
                        <page string="选项" name="options"
                              invisible="question_type not in ('single_choice', 'multi_choice')">
                            <group>
                                <group>
                                    <field name="option_a"/>
                                    <field name="option_b"/>
                                    <field name="option_c"/>
                                </group>
                                <group>
                                    <field name="option_d"/>
                                    <field name="option_e"/>
                                    <field name="option_f"/>
                                </group>
                            </group>
                        </page>
                        <page string="答案" name="answer">
                            <group>
                                <field name="correct_answer"
                                       placeholder="选择题填选项字母如 A 或 AB，填空题用 | 分隔多个空"/>
                                <field name="reference_answer"
                                       placeholder="参考答案（填空/计算/问答）"/>
                            </group>
                        </page>
                        <page string="答案解析" name="explanation">
                            <field name="answer_explanation" widget="html" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>


    <record id="action_learn_question" model="ir.actions.act_window">
        <field name="name">题目</field>
        <field name="res_model">learn.question</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{}</field>
    </record>


</odoo>
