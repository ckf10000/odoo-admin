<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- 分类树视图 -->
    <record id="view_learn_category_tree" model="ir.ui.view">
        <field name="name">learn.category.tree</field>
        <field name="model">learn.category</field>
        <field name="arch" type="xml">
            <tree string="学习分类">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="audience_type"/>
                <field name="show_in_nav" widget="boolean_toggle"/>
                <field name="stage_info"/>
                <field name="level" optional="hide"/>
                <field name="is_leaf" optional="hide"/>
                <field name="content_count"/>
                <field name="item_count"/>
                <field name="parent_id" invisible="1"/>
            </tree>
        </field>
    </record>

    <!-- 分类表单视图 -->
    <record id="view_learn_category_form" model="ir.ui.view">
        <field name="name">learn.category.form</field>
        <field name="model">learn.category</field>
        <field name="arch" type="xml">
            <form string="学习分类">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_contents" type="object"
                                class="oe_stat_button" icon="fa-book">
                            <field name="content_count" widget="statinfo" string="内容"/>
                        </button>
                        <button name="action_view_items" type="object"
                                class="oe_stat_button" icon="fa-cubes">
                            <field name="item_count" widget="statinfo" string="知识点"/>
                        </button>
                        <button name="action_view_words" type="object"
                                class="oe_stat_button" icon="fa-language">
                            <field name="word_count" widget="statinfo" string="单词"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="末级分类" bg_color="bg-success"
                            invisible="not is_leaf"/>
                    <field name="is_leaf" invisible="1"/>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="parent_id"/>
                            <field name="audience_type"/>
                            <field name="stage_info"/>
                            <field name="level" readonly="1"/>
                        </group>
                    </group>
                    <group string="导航设置">
                        <field name="show_in_nav"/>
                        <field name="nav_icon" widget="image" class="oe_avatar"/>
                        <field name="nav_icon_active" widget="image" class="oe_avatar"/>
                    </group>
                    <group string="描述">
                        <field name="description" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- 分类搜索视图 -->
    <record id="view_learn_category_search" model="ir.ui.view">
        <field name="name">learn.category.search</field>
        <field name="model">learn.category</field>
        <field name="arch" type="xml">
            <search string="搜索分类">
                <field name="name"/>
                <field name="code"/>
                <filter name="root_only" string="根分类"
                        domain="[('parent_id', '=', False)]"/>
                <filter name="nav_tabs" string="导航 Tab"
                        domain="[('show_in_nav', '=', True)]"/>
                <filter name="leaf_only" string="末级分类"
                        domain="[('is_leaf', '=', True)]"/>
                <separator/>
                <filter name="audience_enlightenment" string="思维启蒙"
                        domain="[('audience_type', '=', 'enlightenment')]"/>
                <filter name="audience_children" string="少儿教育"
                        domain="[('audience_type', '=', 'children')]"/>
                <filter name="audience_nine_year" string="九年义务"
                        domain="[('audience_type', '=', 'nine_year')]"/>
                <filter name="audience_adult" string="成人教育"
                        domain="[('audience_type', '=', 'adult')]"/>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_learn_category" model="ir.actions.act_window">
        <field name="name">学习分类</field>
        <field name="res_model">learn.category</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{}</field>
    </record>

</odoo>
