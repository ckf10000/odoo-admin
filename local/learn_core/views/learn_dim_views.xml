<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ========== 8 个维度表通用视图 ========== -->

    <!-- 分类 -->
    <record id="view_learn_dim_category_tree" model="ir.ui.view">
        <field name="name">learn.dim.category.tree</field>
        <field name="model">learn.dim.category</field>
        <field name="arch" type="xml">
            <tree string="分类" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="active" widget="boolean_toggle"/>
                <field name="description" optional="hide"/>
            </tree>
        </field>
    </record>
    <record id="view_learn_dim_category_form" model="ir.ui.view">
        <field name="name">learn.dim.category.form</field>
        <field name="model">learn.dim.category</field>
        <field name="arch" type="xml">
            <form string="分类">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                    </group>
                    <group>
                        <field name="sequence"/>
                        <field name="active"/>
                        <field name="icon" widget="image" class="oe_avatar"/>
                    </group>
                    <group string="描述">
                        <field name="description" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

