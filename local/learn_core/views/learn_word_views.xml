<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ========== 单词 视图 ========== -->

    <record id="view_learn_word_tree" model="ir.ui.view">
        <field name="name">learn.word.tree</field>
        <field name="model">learn.word</field>
        <field name="arch" type="xml">
            <tree string="单词列表">
                <field name="name"/>
                <field name="phonetic"/>
                <field name="part_of_speech" widget="badge"/>
                <field name="meaning"/>
                <field name="source_ids"/>
                <field name="difficulty" widget="badge"/>
            </tree>
        </field>
    </record>

    <record id="view_learn_word_form" model="ir.ui.view">
        <field name="name">learn.word.form</field>
        <field name="model">learn.word</field>
        <field name="arch" type="xml">
            <form string="单词">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="phonetic"/>
                        <field name="part_of_speech"/>
                        <field name="difficulty"/>
                    </group>
                    <group>
                        <field name="source_ids"/>
                        <field name="active"/>
                    </group>
                    <group string="释义">
                        <field name="meaning"/>
                        <field name="meaning_en"/>
                    </group>
                    <group string="例句与短语">
                        <field name="example_sentence"/>
                        <field name="phrases"/>
                        <field name="etymology"/>
                    </group>
                    <group string="备注">
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_learn_word_search" model="ir.ui.view">
        <field name="name">learn.word.search</field>
        <field name="model">learn.word</field>
        <field name="arch" type="xml">
            <search string="搜索单词">
                <field name="name"/>
                <field name="meaning"/>
                <field name="source_ids"/>
                <filter name="filter_easy" string="简单"
                        domain="[('difficulty', '=', 'easy')]"/>
                <filter name="filter_medium" string="中等"
                        domain="[('difficulty', '=', 'medium')]"/>
                <filter name="filter_hard" string="困难"
                        domain="[('difficulty', '=', 'hard')]"/>
                <group expand="0" string="按词性分组">
                    <filter name="pos_noun" string="名词"
                            domain="[('part_of_speech', '=', 'noun')]"/>
                    <filter name="pos_verb" string="动词"
                            domain="[('part_of_speech', '=', 'verb')]"/>
                    <filter name="pos_adj" string="形容词"
                            domain="[('part_of_speech', '=', 'adj')]"/>
                    <filter name="pos_adv" string="副词"
                            domain="[('part_of_speech', '=', 'adv')]"/>
                    <filter name="pos_phrase" string="短语"
                            domain="[('part_of_speech', '=', 'phrase')]"/>
                </group>
            </search>
        </field>
    </record>

</odoo>
