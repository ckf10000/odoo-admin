<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ========== 音频 ========== -->
    <record id="view_learn_audio_tree" model="ir.ui.view">
        <field name="name">learn.audio.tree</field>
        <field name="model">learn.audio</field>
        <field name="arch" type="xml">
            <tree string="音频">
                <field name="name"/>
                <field name="duration"/>
            </tree>
        </field>
    </record>
    <record id="view_learn_audio_form" model="ir.ui.view">
        <field name="name">learn.audio.form</field>
        <field name="model">learn.audio</field>
        <field name="arch" type="xml">
            <form string="音频">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="url" widget="url"/>
                        <field name="duration"/>
                        <field name="file_data" filename="file_name"/>
                        <field name="file_name" invisible="1"/>
                        <field name="active"/>
                    </group>
                    <group string="描述">
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ========== 视频 ========== -->
    <record id="view_learn_video_tree" model="ir.ui.view">
        <field name="name">learn.video.tree</field>
        <field name="model">learn.video</field>
        <field name="arch" type="xml">
            <tree string="视频">
                <field name="name"/>
                <field name="duration"/>
            </tree>
        </field>
    </record>
    <record id="view_learn_video_form" model="ir.ui.view">
        <field name="name">learn.video.form</field>
        <field name="model">learn.video</field>
        <field name="arch" type="xml">
            <form string="视频">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="url" widget="url"/>
                        <field name="duration"/>
                        <field name="file_data" filename="file_name"/>
                        <field name="file_name" invisible="1"/>
                        <field name="active"/>
                    </group>
                    <group string="描述">
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ========== 文档 ========== -->
    <record id="view_learn_document_tree" model="ir.ui.view">
        <field name="name">learn.document.tree</field>
        <field name="model">learn.document</field>
        <field name="arch" type="xml">
            <tree string="文档">
                <field name="name"/>
                <field name="file_name"/>
            </tree>
        </field>
    </record>
    <record id="view_learn_document_form" model="ir.ui.view">
        <field name="name">learn.document.form</field>
        <field name="model">learn.document</field>
        <field name="arch" type="xml">
            <form string="文档">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="url" widget="url"/>
                        <field name="file_data" filename="file_name"/>
                        <field name="file_name" invisible="1"/>
                        <field name="active"/>
                    </group>
                    <group string="描述">
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ========== 图片 ========== -->
    <record id="view_learn_image_tree" model="ir.ui.view">
        <field name="name">learn.image.tree</field>
        <field name="model">learn.image</field>
        <field name="arch" type="xml">
            <tree string="图片">
                <field name="name"/>
                <field name="file_name"/>
            </tree>
        </field>
    </record>
    <record id="view_learn_image_form" model="ir.ui.view">
        <field name="name">learn.image.form</field>
        <field name="model">learn.image</field>
        <field name="arch" type="xml">
            <form string="图片">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="url" widget="url"/>
                        <field name="image_data" widget="image"/>
                        <field name="file_name" invisible="1"/>
                        <field name="active"/>
                    </group>
                    <group string="描述">
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ========== 题目库 ========== -->
    <record id="view_learn_question_bank_tree" model="ir.ui.view">
        <field name="name">learn.question.bank.tree</field>
        <field name="model">learn.question.bank</field>
        <field name="arch" type="xml">
            <tree string="题目">
                <field name="name"/>
                <field name="question_type" widget="badge"/>
                <field name="difficulty" widget="badge"/>
            </tree>
        </field>
    </record>
    <record id="view_learn_question_bank_form" model="ir.ui.view">
        <field name="name">learn.question.bank.form</field>
        <field name="model">learn.question.bank</field>
        <field name="arch" type="xml">
            <form string="题目">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="题目标题"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="question_type"/>
                            <field name="default_score"/>
                            <field name="difficulty"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="题干" name="stem">
                            <field name="stem" widget="html" nolabel="1"/>
                            <field name="stem_image" widget="image" nolabel="1"/>
                        </page>
                        <page string="选项" name="options"
                              invisible="question_type not in ('single_choice', 'multi_choice')">
                            <group>
                                <group>
                                    <field name="option_a"/>
                                    <field name="option_b"/>
                                    <field name="option_c"/>
                                </group>
                                <group>
                                    <field name="option_d"/>
                                    <field name="option_e"/>
                                    <field name="option_f"/>
                                </group>
                            </group>
                        </page>
                        <page string="答案" name="answer">
                            <group>
                                <field name="correct_answer"/>
                                <field name="reference_answer"/>
                            </group>
                        </page>
                        <page string="答案解析" name="explanation">
                            <field name="answer_explanation" widget="html" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
