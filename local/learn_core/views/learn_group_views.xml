<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ========== 内容组 视图 ========== -->

    <record id="view_learn_group_tree" model="ir.ui.view">
        <field name="name">learn.group.tree</field>
        <field name="model">learn.group</field>
        <field name="arch" type="xml">
            <tree string="内容组">
                <field name="name"/>
                <field name="content_type_id"/>
                <field name="selector_id"/>
                <field name="selector_process_id"/>
            </tree>
        </field>
    </record>

    <record id="view_learn_group_form" model="ir.ui.view">
        <field name="name">learn.group.form</field>
        <field name="model">learn.group</field>
        <field name="arch" type="xml">
            <form string="内容组">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="selector_id"/>
                            <field name="selector_process_id"/>
                            <field name="content_type_id"/>
                        </group>
                        <group>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="内容列表" name="items">
                            <field name="line_ids" nolabel="1"
                                   context="{'default_content_type_id': content_type_id}">
                                <tree editable="bottom">
                                    <field name="title"/>
                                    <field name="phonetic" optional="hide"/>
                                    <field name="meaning" optional="hide"/>
                                    <field name="sequence" widget="handle"/>
                                </tree>
                                <form string="内容条目">
                                    <sheet>
                                        <field name="group_id" invisible="1"/>
                                        <group>
                                            <field name="sequence"/>
                                        </group>
                                        <group string="单词"
                                               attrs="{'invisible': [('parent.content_type', '!=', 'word')]}">
                                            <field name="word_id"/>
                                            <field name="phonetic"/>
                                            <field name="meaning"/>
                                        </group>
                                        <group string="视频"
                                               attrs="{'invisible': [('parent.content_type', '!=', 'video')]}">
                                            <field name="video_title"/>
                                            <field name="video_url"/>
                                            <field name="video_duration"/>
                                        </group>
                                        <group string="文件"
                                               attrs="{'invisible': [('parent.content_type', '!=', 'file')]}">
                                            <field name="file_name"/>
                                            <field name="file_data" filename="file_name"/>
                                        </group>
                                        <group string="知识要点"
                                               attrs="{'invisible': [('parent.content_type', '!=', 'knowledge')]}">
                                            <field name="knowledge_title"/>
                                            <field name="knowledge_content"/>
                                        </group>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                        <page string="描述" name="description">
                            <field name="description"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
