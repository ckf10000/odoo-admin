<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_learn_media_tree" model="ir.ui.view">
        <field name="name">learn.media.tree</field>
        <field name="model">learn.media</field>
        <field name="arch" type="xml">
            <tree string="媒体">
                <field name="name"/>
                <field name="media_type"/>
                <field name="duration" optional="show"/>
            </tree>
        </field>
    </record>

    <record id="view_learn_media_form" model="ir.ui.view">
        <field name="name">learn.media.form</field>
        <field name="model">learn.media</field>
        <field name="arch" type="xml">
            <form string="媒体">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="media_type"/>
                        <field name="url"
                               invisible="media_type == 'file'"/>
                        <field name="duration"
                               invisible="media_type == 'file'"/>
                        <field name="file_data" filename="file_name"
                               invisible="media_type != 'file'"/>
                        <field name="file_name"
                               invisible="media_type != 'file'"/>
                        <field name="sequence"/>
                        <field name="active"/>
                    </group>
                    <group>
                        <field name="selector_ids"/>
                    </group>
                    <group string="描述">
                        <field name="description" colspan="2"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
