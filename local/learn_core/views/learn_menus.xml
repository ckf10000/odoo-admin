              name="内容类型" parent="menu_learn_content" sequence="3"
              action="action_learn_content_type"/>

    <record id="action_learn_question" model="ir.actions.act_window">
        <field name="name">题目</field>
        <field name="res_model">learn.question</field>
        <field name="view_mode">tree,form</field>
    </record>
    <menuitem id="menu_learn_question"
              name="题目"
              parent="menu_learn_content"
              sequence="7"
              action="action_learn_question"/>

    <record id="action_learn_word_source" model="ir.actions.act_window">
        <field name="name">内容来源</field>
        <field name="res_model">learn.content.source</field>
        <field name="view_mode">tree,form</field>
    </record>
    <menuitem id="menu_learn_word_source"
              name="内容来源" parent="menu_learn_content" sequence="4"
              action="action_learn_word_source"/>

    <!-- 知识库管理（一级菜单） -->
    <menuitem id="menu_learn_knowledge_base"
              name="知识库管理"
              parent="menu_learn_root"
              sequence="11"/>

    <record id="action_learn_word" model="ir.actions.act_window">
        <field name="name">单词库</field>
        <field name="res_model">learn.word</field>
        <field name="view_mode">tree,form</field>
    </record>
    <menuitem id="menu_learn_word"
              name="单词库" parent="menu_learn_knowledge_base" sequence="10"
              action="action_learn_word"/>

    <record id="action_learn_character" model="ir.actions.act_window">
        <field name="name">生字库</field>
        <field name="res_model">learn.character</field>
        <field name="view_mode">tree,form</field>
    </record>
    <menuitem id="menu_learn_character"
              name="生字库" parent="menu_learn_knowledge_base" sequence="20"
              action="action_learn_character"/>

    <record id="action_learn_phrase" model="ir.actions.act_window">
