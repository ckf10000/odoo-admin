        <field name="res_model">learn.phrase</field>
        <field name="view_mode">tree,form</field>
    </record>
    <menuitem id="menu_learn_phrase"
              name="字词" parent="menu_learn_content" sequence="9"
              action="action_learn_phrase"/>

    <!-- 过程管理（一级菜单） -->
    <menuitem id="menu_learn_workflow"
              name="过程管理"
              parent="menu_learn_root"
              sequence="15"/>

    <record id="action_learn_group" model="ir.actions.act_window">
        <field name="name">内容组</field>
        <field name="res_model">learn.group</field>
        <field name="view_mode">tree,form</field>
    </record>
    <menuitem id="menu_learn_group"
              name="内容组" parent="menu_learn_content" sequence="20"
              action="action_learn_group"/>

    <record id="action_learn_media" model="ir.actions.act_window">
        <field name="name">媒体</field>
        <field name="res_model">learn.media</field>
        <field name="view_mode">tree,form</field>
    </record>
    <menuitem id="menu_learn_media"
              name="媒体" parent="menu_learn_content" sequence="5"
              action="action_learn_media"/>

    <record id="action_learn_article" model="ir.actions.act_window">
        <field name="name">图文</field>
        <field name="res_model">learn.article</field>
        <field name="view_mode">tree,form</field>
    </record>
    <menuitem id="menu_learn_article"
              name="图文" parent="menu_learn_content" sequence="6"
              action="action_learn_article"/>

    <!-- 学习管理（TODO: learn.favorite / rating / wrong.book / exam.session 模型待建） -->
    <menuitem id="menu_learn_study"
              name="学习管理"
              parent="menu_learn_root"
              sequence="20"/>

</odoo>
