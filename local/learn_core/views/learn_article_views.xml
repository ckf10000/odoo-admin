<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_learn_article_tree" model="ir.ui.view">
        <field name="name">learn.article.tree</field>
        <field name="model">learn.article</field>
        <field name="arch" type="xml">
            <tree string="图文">
                <field name="name"/>
                <field name="article_type"/>
                <field name="tags" optional="show"/>
            </tree>
        </field>
    </record>

    <record id="view_learn_article_form" model="ir.ui.view">
        <field name="name">learn.article.form</field>
        <field name="model">learn.article</field>
        <field name="arch" type="xml">
            <form string="图文">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="标题"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="article_type"/>
                            <field name="tags"/>
                        </group>
                        <group>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group>
                        <field name="selector_ids"/>
                    </group>
                    <notebook>
                        <page string="正文" name="content">
                            <field name="content_edit_mode" invisible="1"/>
                            <div class="d-flex justify-content-end mb-2">
                                <button name="action_edit_content" type="object"
                                        string="编辑" class="btn-secondary btn-sm"
                                        invisible="content_edit_mode"/>
                                <button name="action_save_content" type="object"
                                        string="保存" class="btn-primary btn-sm"
                                        invisible="not content_edit_mode"/>
                                <button name="action_cancel_content" type="object"
                                        string="取消" class="btn-secondary btn-sm"
                                        invisible="not content_edit_mode"/>
                            </div>
                            <field name="content" widget="html" readonly="not content_edit_mode"/>
                        </page>
                        <page string="摘要" name="description">
                            <field name="description"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
