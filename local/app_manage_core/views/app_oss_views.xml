<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- OSS 配置 Tree -->
    <record id="view_app_oss_config_tree" model="ir.ui.view">
        <field name="name">app.oss.config.tree</field>
        <field name="model">app.oss.config</field>
        <field name="arch" type="xml">
            <tree string="OSS 配置">
                <field name="name"/>
                <field name="code"/>
                <field name="endpoint"/>
                <field name="bucket_name"/>
                <field name="custom_domain"/>
                <field name="active"/>
                <field name="last_upload_time" optional="hide"/>
            </tree>
        </field>
    </record>

    <!-- OSS 配置 Form -->
    <record id="view_app_oss_config_form" model="ir.ui.view">
        <field name="name">app.oss.config.form</field>
        <field name="model">app.oss.config</field>
        <field name="arch" type="xml">
            <form string="OSS 配置">
                <header>
                    <button name="action_test_connection" type="object"
                            string="测试连接" class="btn-primary"/>
                </header>
                <sheet>
                    <group>
                        <group string="基本信息">
                            <field name="name"/>
                            <field name="code"/>
                            <field name="provider"/>
                            <field name="active"/>
                        </group>
                        <group string="连接参数">
                            <field name="endpoint"/>
                            <field name="bucket_name"/>
                            <field name="access_key_id"/>
                            <field name="access_key_secret" password="True"/>
                        </group>
                    </group>
                    <group string="上传策略">
                        <group>
                            <field name="base_path"/>
                            <field name="custom_domain" help="绑定 CDN 自定义域名后，URL 使用此域名（永久有效）"/>
                        </group>
                        <group>
                            <field name="last_upload_time"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- OSS 配置 Action -->
    <record id="action_app_oss_config" model="ir.actions.act_window">
        <field name="name">OSS 配置</field>
        <field name="res_model">app.oss.config</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
