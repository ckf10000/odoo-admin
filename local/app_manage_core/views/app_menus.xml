    <!-- 版本管理组 -->
    <menuitem id="menu_app_version_group"
              name="版本管理"
              parent="menu_app_manage_root"
              sequence="10"/>

    <menuitem id="menu_app_version_baseline"
              name="版本基线库"
              parent="menu_app_version_group"
