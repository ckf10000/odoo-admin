<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- 终端管理 Tree -->
    <record id="view_app_terminal_tree" model="ir.ui.view">
        <field name="name">app.terminal.tree</field>
        <field name="model">app.terminal</field>
        <field name="arch" type="xml">
            <tree string="终端管理">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="platform"/>
                <field name="terminal_type"/>
                <field name="terminal_model"/>
                <field name="terminal_code"/>
                <field name="is_whitelisted" widget="boolean_toggle"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <!-- 终端管理 Form -->
    <record id="view_app_terminal_form" model="ir.ui.view">
        <field name="name">app.terminal.form</field>
        <field name="model">app.terminal</field>
        <field name="arch" type="xml">
            <form string="终端管理">
                <sheet>
                    <group>
                        <group string="基本信息">
                            <field name="platform"/>
                            <field name="terminal_type"/>
                            <field name="terminal_model"/>
                            <field name="terminal_code"/>
                            <field name="manufacturer"/>
                        </group>
                        <group string="状态与限制">
                            <field name="sequence"/>
                            <field name="active"/>
                            <field name="is_whitelisted"/>
                            <field name="min_os_version"/>
                            <field name="max_os_version"/>
                        </group>
                    </group>
                    <group string="关联基线版本">
                        <field name="baseline_ids" widget="many2many_tags"/>
                    </group>
                    <field name="description" nolabel="1" placeholder="备注说明..." colspan="2"/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- 终端管理 Search -->
    <record id="view_app_terminal_search" model="ir.ui.view">
        <field name="name">app.terminal.search</field>
        <field name="model">app.terminal</field>
        <field name="arch" type="xml">
            <search string="搜索终端">
                <field name="name"/>
                <field name="terminal_model"/>
                <field name="terminal_code"/>
                <field name="manufacturer"/>
                <filter name="active" string="已启用" domain="[('active', '=', True)]"/>
                <filter name="whitelisted" string="白名单" domain="[('is_whitelisted', '=', True)]"/>
                <filter name="blacklisted" string="黑名单" domain="[('is_whitelisted', '=', False)]"/>
                <group expand="1" string="按平台">
                    <filter name="platform_ios" string="iOS" domain="[('platform', '=', 'ios')]"/>
                    <filter name="platform_android" string="Android" domain="[('platform', '=', 'android')]"/>
                    <filter name="platform_harmonyos" string="HarmonyOS" domain="[('platform', '=', 'harmonyos')]"/>
                </group>
                <group expand="1" string="按类型">
                    <filter name="type_phone" string="手机" domain="[('terminal_type', '=', 'phone')]"/>
                    <filter name="type_tablet" string="平板" domain="[('terminal_type', '=', 'tablet')]"/>
                    <filter name="type_foldable" string="折叠屏" domain="[('terminal_type', '=', 'foldable')]"/>
                </group>
            </search>
        </field>
    </record>

    <!-- 终端管理 Action -->
    <record id="action_app_terminal" model="ir.actions.act_window">
        <field name="name">终端管理</field>
        <field name="res_model">app.terminal</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{}</field>
    </record>
</odoo>
