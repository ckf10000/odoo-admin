<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- 收藏列表 -->
    <record id="view_learn_favorite_tree" model="ir.ui.view">
        <field name="name">learn.favorite.tree</field>
        <field name="model">learn.favorite</field>
        <field name="arch" type="xml">
            <tree string="我的收藏">
                <field name="content_id"/>
                <field name="content_type"/>
                <field name="user_id"/>
                <field name="create_date"/>
            </tree>
        </field>
    </record>

    <!-- 笔记列表 -->
    <record id="view_learn_note_tree" model="ir.ui.view">
        <field name="name">learn.note.tree</field>
        <field name="model">learn.note</field>
        <field name="arch" type="xml">
            <tree string="学习笔记">
                <field name="title"/>
                <field name="content_id"/>
                <field name="page_number"/>
                <field name="is_private"/>
                <field name="user_id"/>
                <field name="create_date"/>
            </tree>
        </field>
    </record>

    <!-- 笔记表单 -->
    <record id="view_learn_note_form" model="ir.ui.view">
        <field name="name">learn.note.form</field>
        <field name="model">learn.note</field>
        <field name="arch" type="xml">
            <form string="学习笔记">
                <sheet>
                    <group>
                        <field name="title"/>
                        <field name="content_id"/>
                        <field name="page_number"/>
                        <field name="is_private"/>
                    </group>
                    <group string="笔记内容">
                        <field name="content" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- 评分评论列表 -->
    <record id="view_learn_rating_tree" model="ir.ui.view">
        <field name="name">learn.rating.tree</field>
        <field name="model">learn.rating</field>
        <field name="arch" type="xml">
            <tree string="评分评论">
                <field name="content_id"/>
                <field name="user_id"/>
                <field name="score" widget="float_factor"/>
                <field name="comment"/>
                <field name="is_approved"/>
                <field name="create_date"/>
            </tree>
        </field>
    </record>

    <!-- Actions -->
    <record id="action_learn_favorite" model="ir.actions.act_window">
        <field name="name">我的收藏</field>
        <field name="res_model">learn.favorite</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{}</field>
    </record>

    <record id="action_learn_note" model="ir.actions.act_window">
        <field name="name">学习笔记</field>
        <field name="res_model">learn.note</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{}</field>
    </record>

    <record id="action_learn_rating" model="ir.actions.act_window">
        <field name="name">评分评论</field>
        <field name="res_model">learn.rating</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{}</field>
    </record>

</odoo>
