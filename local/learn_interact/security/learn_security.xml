<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- 用户数据隔离规则：用户只能看到自己的答题记录、收藏、笔记等 -->
        <record id="rule_exam_session_user" model="ir.rule">
            <field name="name">用户只能看到自己的答题记录</field>
            <field name="model_id" ref="model_learn_exam_session"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <record id="rule_favorite_user" model="ir.rule">
            <field name="name">用户只能看到自己的收藏</field>
            <field name="model_id" ref="model_learn_favorite"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="rule_annotation_user" model="ir.rule">
            <field name="name">用户只能看到自己的批注</field>
            <field name="model_id" ref="model_learn_annotation"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="rule_note_user" model="ir.rule">
            <field name="name">用户只能看到自己的笔记</field>
            <field name="model_id" ref="model_learn_note"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="rule_wrong_book_user" model="ir.rule">
            <field name="name">用户只能看到自己的错题本</field>
            <field name="model_id" ref="model_learn_wrong_book"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

    </data>
</odoo>
